#!/usr/bin/env bash
set -e

if [[ "$(uname)" == "Darwin" ]]; then
  formulae=(
    git
    neovim
    fzf
    lazygit
    ripgrep
    fd
    jq
    gh
    zoxide
    bat
    eza
  )

  casks=(
  {{ if ne .chezmoi.hostname "GCF-AEMELYANOV-MAC" }}
    visual-studio-code
    hammerspoon
  {{ end }}
  )

  # Install CLI tools
  for pkg in "${formulae[@]}"; do
    if ! brew list "$pkg" >/dev/null 2>&1; then
      brew install "$pkg"
    fi
  done

  # Install GUI apps
  for app in "${casks[@]}"; do
    if ! brew list --cask "$app" >/dev/null 2>&1; then
      brew install --cask "$app"
    fi
  done
fi
